{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "after 11pm every weekday",
    "before 7am every weekday",
    "every weekend"
  ],
  "timezone": "Europe/Brussels",
  "reviewers": [
    "team:maintainers"
  ],
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    },
    {
      "matchDepNames": [
        "github.com/urfave/cli/v3"
      ],
      "enabled": false
    },
    {
      "groupName": "repositories",
      "matchPackageNames": [
        "/^quay.io/kairos/packages*/"
      ]
    },
    {
      "versioning": "regex:^(?<major>\\d{12})-git(?<patch>[a-f0-9]{8})-repository\\.yaml$",
      "matchPackageNames": [
        "/^quay.io/kairos/packages*/"
      ]
    },
    {
      "enabled": true,
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "major"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/image-assets/luet-amd64.yaml$/",
        "/image-assets/luet-arm64.yaml$/"
      ],
      "matchStrings": [
        "\\s*#\\s*renovate:\\s*datasource=(?<datasource>.*?) depName=(?<depName>.*?)?\\s+reference:\\s(?<currentValue>.*?)\\s"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/internal/builder/auroraboot/constants\\.go$/"
      ],
      "matchStrings": [
        "defaultKairosInitVersion\\s*=\\s*\"v(?<currentValue>[0-9.]+)\""
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "quay.io/kairos/kairos-init"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/ui/src/pages/ArtifactBuilder\\.tsx$/"
      ],
      "matchStrings": [
        "//\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*\\n\\s*baseImage:\\s*\"[^\"]+:(?<currentValue>[^\"]+)\"",
        "//\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+extractVersion=(?<extractVersion>\\S+))?\\s*\\n\\s*const\\s+\\w+\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ]
    }
  ]
}
